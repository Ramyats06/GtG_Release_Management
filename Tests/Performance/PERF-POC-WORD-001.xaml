    <ui:InvokePowerShell x:TypeArguments="x:String" ContinueOnError="{x:Null}" CommandText="param(&#xA;    [string]$ProcessName,&#xA;    [int]$DurationSeconds = 30,&#xA;    [int]$SampleIntervalSeconds = 2,&#xA;    [int]$StartupTimeoutSeconds = 60&#xA;)&#xA;&#xA;$results = @{&#xA;    ProcessName = $ProcessName&#xA;    StartupTime = 0&#xA;    StartupSuccess = $false&#xA;    AverageCPU = 0&#xA;    MaxCPU = 0&#xA;    StartupPeakCPU = 0&#xA;    AverageMemoryMB = 0&#xA;    MaxMemoryMB = 0&#xA;    StartupPeakMemoryMB = 0&#xA;    SampleCount = 0&#xA;    Error = $null&#xA;}&#xA;&#xA;# Phase 1: Wait for process to start and measure startup time&#xA;$startupStartTime = Get-Date&#xA;$processFound = $false&#xA;$startupElapsed = 0&#xA;&#xA;&#xA;&#xA;While ($startupElapsed -lt $StartupTimeoutSeconds -And -Not $processFound) {&#xA;    $process = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue&#xA;   &#xA;    If ($process) {&#xA;        $processFound = $True&#xA;        $startupEndTime = Get-Date&#xA;        $results.StartupTime = [math]::Round(($startupEndTime - $startupStartTime).TotalSeconds, 2)&#xA;        $results.StartupSuccess = $True&#xA;        Write-Host 'Process found! Startup time: $($results.StartupTime) seconds'&#xA;        break&#xA;    }&#xA;   &#xA;    Start-Sleep -Milliseconds 100&#xA;    $startupElapsed = ((Get-Date) - $startupStartTime).TotalSeconds&#xA;}&#xA;&#xA;If (-Not $processFound) {&#xA;    $results.Error = 'Process did not start within $StartupTimeoutSeconds seconds'&#xA;    $results.StartupTime = $StartupTimeoutSeconds&#xA;    Write-Output ($results | ConvertTo-Json)&#xA;    Exit&#xA;}&#xA;&#xA;# Phase 2: Monitor startup stabilization (first 10 seconds after process starts)&#xA;Write-Host 'Monitoring startup phase...'&#xA;$startupSamples = @()&#xA;$startupMonitorEnd = (Get-Date).AddSeconds(10)&#xA;&#xA;While ((Get-Date) -lt $startupMonitorEnd) {&#xA;    $process = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue&#xA;   &#xA;    If ($process) {&#xA;        $cpuBefore = $process.CPU&#xA;        $timeBefore = Get-Date&#xA;       &#xA;        Start-Sleep -Milliseconds 500&#xA;       &#xA;        $process = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue&#xA;        If ($process) {&#xA;            $cpuAfter = $process.CPU&#xA;            $timeAfter = Get-Date&#xA;           &#xA;            $cpuDelta = $cpuAfter - $cpuBefore&#xA;            $timeDelta = ($timeAfter - $timeBefore).TotalSeconds&#xA;           &#xA;            $cpuPercent = If ($timeDelta -gt 0) {&#xA;                ($cpuDelta / $timeDelta)&#xA;            } Else {&#xA;                0&#xA;            }&#xA;           &#xA;            $memoryMB = [math]::Round($process.WorkingSet64 / 1MB, 2)&#xA;           &#xA;            $startupSamples += [PSCustomObject]@{&#xA;                Timestamp = Get-Date -Format 'yyyy-MM-dd HH:mm:ss.fff'&#xA;                CPU = [math]::Round($cpuPercent, 2)&#xA;                MemoryMB = $memoryMB&#xA;                Phase = 'Startup'&#xA;            }&#xA;        }&#xA;    }&#xA;}&#xA;&#xA;# Calculate startup phase peaks&#xA;If ($startupSamples.Count -gt 0) {&#xA;    $results.StartupPeakCPU = [math]::Round(($startupSamples | Measure-Object -Property CPU -Maximum).Maximum, 2)&#xA;    $results.StartupPeakMemoryMB = [math]::Round(($startupSamples | Measure-Object -Property MemoryMB -Maximum).Maximum, 2)&#xA;}&#xA;&#xA;# Phase 3: Monitor steady-state performance&#xA;Write-Host 'Monitoring steady-state performance...'&#xA;$steadyStateSamples = @()&#xA;$endTime = (Get-Date).AddSeconds($DurationSeconds)&#xA;&#xA;While ((Get-Date) -lt $endTime) {&#xA;    $process = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue&#xA;   &#xA;    If ($process) {&#xA;        $cpuBefore = $process.CPU&#xA;        $timeBefore = Get-Date&#xA;       &#xA;        Start-Sleep -Seconds $SampleIntervalSeconds&#xA;       &#xA;        $process = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue&#xA;        If ($process) {&#xA;            $cpuAfter = $process.CPU&#xA;            $timeAfter = Get-Date&#xA;           &#xA;            $cpuDelta = $cpuAfter - $cpuBefore&#xA;            $timeDelta = ($timeAfter - $timeBefore).TotalSeconds&#xA;           &#xA;            $cpuPercent = If ($timeDelta -gt 0) {&#xA;                ($cpuDelta / $timeDelta)&#xA;            } Else {&#xA;                0&#xA;            }&#xA;           &#xA;            $memoryMB = [math]::Round($process.WorkingSet64 / 1MB, 2)&#xA;           &#xA;            $steadyStateSamples += [PSCustomObject]@{&#xA;                Timestamp = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'&#xA;                CPU = [math]::Round($cpuPercent, 2)&#xA;                MemoryMB = $memoryMB&#xA;                Phase = 'SteadyState'&#xA;            }&#xA;        }&#xA;    } Else {&#xA;        Write-Host 'Process terminated during monitoring'&#xA;        break&#xA;    }&#xA;}&#xA;&#xA;# Combine all samples&#xA;$allSamples = $startupSamples + $steadyStateSamples&#xA;&#xA;# Calculate overall statistics&#xA;If ($allSamples.Count -gt 0) {&#xA;    $results.AverageCPU = [math]::Round(($allSamples | Measure-Object -Property CPU -Average).Average, 2)&#xA;    $results.MaxCPU = [math]::Round(($allSamples | Measure-Object -Property CPU -Maximum).Maximum, 2)&#xA;    $results.AverageMemoryMB = [math]::Round(($allSamples | Measure-Object -Property MemoryMB -Average).Average, 2)&#xA;    $results.MaxMemoryMB = [math]::Round(($allSamples | Measure-Object -Property MemoryMB -Maximum).Maximum, 2)&#xA;    $results.SampleCount = $allSamples.Count&#xA;}&#xA;&#xA;# Calculate steady-state only statistics&#xA;$steadyStateStats = @{&#xA;    AverageCPU = 0&#xA;    AverageMemoryMB = 0&#xA;}&#xA;&#xA;If ($steadyStateSamples.Count -gt 0) {&#xA;    $steadyStateStats.AverageCPU = [math]::Round(($steadyStateSamples | Measure-Object -Property CPU -Average).Average, 2)&#xA;    $steadyStateStats.AverageMemoryMB = [math]::Round(($steadyStateSamples | Measure-Object -Property MemoryMB -Average).Average, 2)&#xA;}&#xA;&#xA;$results.SteadyStateAverageCPU = $steadyStateStats.AverageCPU&#xA;$results.SteadyStateAverageMemoryMB = $steadyStateStats.AverageMemoryMB&#xA;&#xA;Write-Host 'Monitoring complete. Total samples: $($allSamples.Count)'&#xA;&#xA;# Return comprehensive results&#xA;$results | ConvertTo-Json&#xA;&#xA;" DisplayName="Invoke Power Shell" sap:VirtualizedContainerService.HintSize="452.6666666666667,112.66666666666667" sap2010:WorkflowViewState.IdRef="InvokePowerShell`1_4" IsScript="True" Output="[performanceResults]" PowerShellProcess="WindowsPowerShell64">
