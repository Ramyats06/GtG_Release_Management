                  <ui:InvokePowerShell x:TypeArguments="x:String" ContinueOnError="{x:Null}" CommandText="param(&#xA;    [string]$ProcessName,&#xA;    [int]$DurationSeconds = 30,&#xA;    [int]$SampleIntervalSeconds = 2,&#xA;    [int]$StartupTimeoutSeconds = 60,&#xA;    [int]$StartupMonitorDuration = 10&#xA;)&#xA; &#xA;$results = @{&#xA;    ProcessName = $ProcessName&#xA;    StartupTime = 0&#xA;    StartupSuccess = $false&#xA;    StartupMonitored = $false&#xA;    StartupPeakCPU = 0&#xA;    StartupAverageCPU = 0&#xA;    StartupPeakMemoryMB = 0&#xA;    StartupAverageMemoryMB = 0&#xA;    StartupSampleCount = 0&#xA;    AverageCPU = 0&#xA;    MaxCPU = 0&#xA;    MinCPU = 0&#xA;    AverageMemoryMB = 0&#xA;    MaxMemoryMB = 0&#xA;    MinMemoryMB = 0&#xA;    SteadyStateAverageCPU = 0&#xA;    SteadyStateMaxCPU = 0&#xA;    SteadyStateAverageMemoryMB = 0&#xA;    SteadyStateMaxMemoryMB = 0&#xA;    SteadyStateSampleCount = 0&#xA;    ProcessID = 0&#xA;    ProcessStartTime = ''&#xA;    ProcessThreadCount = 0&#xA;    ProcessHandleCount = 0&#xA;    TotalSampleCount = 0&#xA;    MonitoringDuration = 0&#xA;    CPUCores = 0&#xA;    Error = $null&#xA;    Warnings = @()&#xA;}&#xA; &#xA;try {&#xA;    $results.CPUCores = (Get-WmiObject Win32_ComputerSystem).NumberOfLogicalProcessors&#xA;} catch {&#xA;    $results.CPUCores = [Environment]::ProcessorCount&#xA;}&#xA; &#xA;$startupSamples = @()&#xA;$steadyStateSamples = @()&#xA;$allSamples = @()&#xA; &#xA;if ($StartupTimeoutSeconds -gt 0) {&#xA;    $startupWaitStart = Get-Date&#xA;    $processFound = $false&#xA;    $startupElapsed = 0&#xA; &#xA;    while ($startupElapsed -lt $StartupTimeoutSeconds -and -not $processFound) {&#xA;        $process = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue&#xA;     &#xA;        if ($process) {&#xA;            $processFound = $true&#xA;            $startupWaitEnd = Get-Date&#xA;            $results.StartupTime = [math]::Round(($startupWaitEnd - $startupWaitStart).TotalSeconds, 3)&#xA;            $results.StartupSuccess = $true&#xA;            $results.ProcessID = $process.Id&#xA;            $results.ProcessStartTime = $process.StartTime.ToString('yyyy-MM-dd HH:mm:ss.fff')&#xA;            break&#xA;        }&#xA;     &#xA;        Start-Sleep -Milliseconds 100&#xA;        $startupElapsed = ((Get-Date) - $startupWaitStart).TotalSeconds&#xA;    }&#xA; &#xA;    if (-not $processFound) {&#xA;        $results.Error = 'Process did not start within timeout period'&#xA;        Write-Output ($results | ConvertTo-Json -Depth 3)&#xA;        exit 1&#xA;    }&#xA;} else {&#xA;    $process = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue&#xA; &#xA;    if (-not $process) {&#xA;        $results.Error = 'Process is not running'&#xA;        Write-Output ($results | ConvertTo-Json -Depth 3)&#xA;        exit 1&#xA;    }&#xA; &#xA;    $results.ProcessID = $process.Id&#xA;    $results.ProcessStartTime = $process.StartTime.ToString('yyyy-MM-dd HH:mm:ss.fff')&#xA;    $results.StartupSuccess = $true&#xA;}&#xA; &#xA;if ($StartupTimeoutSeconds -gt 0 -and $StartupMonitorDuration -gt 0) {&#xA;    $results.StartupMonitored = $true&#xA;    $startupMonitorStart = Get-Date&#xA;    $startupMonitorEnd = $startupMonitorStart.AddSeconds($StartupMonitorDuration)&#xA;    $startupSampleInterval = [math]::Min(1, $SampleIntervalSeconds)&#xA; &#xA;    while ((Get-Date) -lt $startupMonitorEnd) {&#xA;        $process = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue&#xA;     &#xA;        if (-not $process) {&#xA;            $results.Warnings += 'Process terminated during startup monitoring'&#xA;            break&#xA;        }&#xA;     &#xA;        try {&#xA;            $cpuBefore = $process.CPU&#xA;            $timeBefore = Get-Date&#xA;            Start-Sleep -Milliseconds ($startupSampleInterval * 1000)&#xA;            $process = Get-Process -Name $ProcessName -ErrorAction SilentlyContinue&#xA;         &#xA;            if ($process) {&#xA;                $cpuAfter = $process.