    <ui:InvokePowerShell x:TypeArguments="sma:PSCustomObject" ContinueOnError="{x:Null}" CommandText="param(&#xA;    [string]$CSVPath,&#xA;    [string]$OutputFolder,&#xA;    [string]$TestRunID&#xA;)&#xA;&#xA;Add-Type -AssemblyName System.Windows.Forms&#xA;Add-Type -AssemblyName System.Windows.Forms.DataVisualization&#xA;Add-Type -AssemblyName System.Drawing&#xA;&#xA;$ErrorActionPreference = 'Stop'&#xA;&#xA;try {&#xA;    if (-not (Test-Path $CSVPath)) {&#xA;        throw ('CSV file not found: {0}' -f $CSVPath)&#xA;    }&#xA;&#xA;    if (-not (Test-Path $OutputFolder)) {&#xA;        New-Item -ItemType Directory -Path $OutputFolder -Force | Out-Null&#xA;    }&#xA;&#xA;    $data = Import-Csv -Path $CSVPath&#xA;   &#xA;    if ($data.Count -eq 0) {&#xA;        throw 'CSV file is empty'&#xA;    }&#xA;&#xA;    $apps = $data | Select-Object -ExpandProperty ApplicationName -Unique | Where-Object { $_ }&#xA;   &#xA;    if ($apps.Count -eq 0) {&#xA;        throw 'No applications found in data'&#xA;    }&#xA;&#xA;    $chartPaths = @()&#xA;    $chartWidth = 1200&#xA;    $chartHeight = 700&#xA;&#xA;    function New-ChartObject {&#xA;        param([string]$Title, [int]$Width, [int]$Height)&#xA;       &#xA;        $chart = New-Object System.Windows.Forms.DataVisualization.Charting.Chart&#xA;        $chart.Width = $Width&#xA;        $chart.Height = $Height&#xA;        $chart.BackColor = [System.Drawing.Color]::White&#xA;       &#xA;        $chartArea = New-Object System.Windows.Forms.DataVisualization.Charting.ChartArea&#xA;        $chartArea.BackColor = [System.Drawing.Color]::White&#xA;        $chartArea.AxisX.MajorGrid.LineColor = [System.Drawing.Color]::LightGray&#xA;        $chartArea.AxisY.MajorGrid.LineColor = [System.Drawing.Color]::LightGray&#xA;        $chartArea.AxisX.LabelStyle.Font = New-Object System.Drawing.Font('Segoe UI', 10)&#xA;        $chartArea.AxisY.LabelStyle.Font = New-Object System.Drawing.Font('Segoe UI', 10)&#xA;        $chart.ChartAreas.Add($chartArea)&#xA