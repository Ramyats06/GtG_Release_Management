                  <p:LoadScript Result="{x:Null}" ScriptFile="{x:Null}" Code="import pandas as pd&#xA;import matplotlib.pyplot as plt&#xA;import seaborn as sns&#xA;import json&#xA;import os&#xA;from pathlib import Path&#xA;&#xA;def generate_all_charts(csv_path, output_folder, test_run_id):&#xA;    &#xA;   &#xA;    # Set style&#xA;    sns.set_style('whitegrid')&#xA;    plt.rcParams['figure.figsize'] = (12, 6)&#xA;    plt.rcParams['font.size'] = 10&#xA;   &#xA;    # Read data&#xA;    df = pd.read_csv(csv_path)&#xA;   &#xA;    # Store chart paths&#xA;    chart_paths = []&#xA;   &#xA;    # Ensure output folder exists&#xA;    os.makedirs(output_folder, exist_ok=True)&#xA;   &#xA;    # Chart 1: Startup Time Comparison&#xA;    chart_path = generate_startup_time_chart(df, output_folder, test_run_id)&#xA;    if chart_path:&#xA;        chart_paths.append(chart_path)&#xA;   &#xA;    # Chart 2: CPU Performance Comparison&#xA;    chart_path = generate_cpu_comparison_chart(df, output_folder, test_run_id)&#xA;    if chart_path:&#xA;        chart_paths.append(chart_path)&#xA;   &#xA;    # Chart 3: Memory Usage Comparison&#xA;    chart_path = generate_memory_comparison_chart(df, output_folder, test_run_id)&#xA;    if chart_path:&#xA;        chart_paths.append(chart_path)&#xA;   &#xA;    # Chart 4: Startup vs Steady State Comparison&#xA;    chart_path = generate_phase_comparison_chart(df, output_folder, test_run_id)&#xA;    if chart_path:&#xA;        chart_paths.append(chart_path)&#xA;   &#xA;    # Chart 5: Overall Performance Heatmap&#xA;    chart_path = generate_performance_heatmap(df, output_folder, test_run_id)&#xA;    if chart_path:&#xA;        chart_paths.append(chart_path)&#xA;   &#xA;    # Chart 6: Time Series (if timestamp data available)&#xA;    chart_path = generate_time_series_chart(df, output_folder, test_run_id)&#xA;    if chart_path:&#xA;        chart_paths.append(chart_path)&#xA;   &#xA;    # Return as JSON string&#xA;    return json.dumps(chart_paths)&#xA;&#xA;&#xA;def generate_startup_time_chart(df, output_folder, test_run_id):&#xA;    &#xA;    try:&#xA;        # Filter startup time metrics&#xA;        startup_df = df[df['MetricName'].str.contains('TotalStartupTime|LaunchTime', na=False)]&#xA;       &#xA;        if startup_df.empty:&#xA;            return None&#xA;       &#xA;        # Pivot data&#xA;        pivot_df = startup_df.pivot_table(&#xA;            index='ApplicationName',&#xA;            columns='MetricName',&#xA;            values='MetricValue',&#xA;            aggfunc='first'&#xA;        )&#xA;       &#xA;        # Create chart&#xA;        fig, ax = plt.subplots(figsize=(12, 6))&#xA;        pivot_df.plot(kind='barh', ax=ax, color=['#FA4616', '#FF6B35'])&#xA;       &#xA;        ax.set_xlabel('Time (Seconds)', fontsize=12, fontweight='bold')&#xA;        ax.set_ylabel('Application', fontsize=12, fontweight='bold')&#xA;        ax.set_title('Application Startup Time Comparison', fontsize=14, fontweight='bold')&#xA;        ax.legend(title='Metric', bbox_to_anchor=(1.05, 1), loc='upper left')&#xA;        ax.grid(axis='x', alpha=0.3)&#xA;       &#xA;        plt.tight_layout()&#xA;       &#xA;        chart_path = os.path.join(output_folder, f'StartupTime_{test_run_id}.png')&#xA;        plt.savefig(chart_path, dpi=300, bbox_inches='tight')&#xA;        plt.close()&#xA;       &#xA;        return chart_path&#xA;    except Exception as e:&#xA;        print(f'Error generating startup time chart: {e}')&#xA;        return None&#xA;&#xA;&#xA;def generate_cpu_comparison_chart(df, output_folder, test_run_id):&#xA;    &#xA;    try:&#xA;        # Filter CPU metrics&#xA;        cpu_df = df[df['MetricCategory'] == 'Performance']&#xA;        cpu_df = cpu_df[cpu_df['MetricName'].str.contains('CPU', na=False)]&#xA;       &#xA;        if cpu_df.empty:&#xA;            return None&#xA;       &#xA;        # Pivot data&#xA;        pivot_df = cpu_df.pivot_table(&#xA;            index='ApplicationName',&#xA;            columns='Phase',&#xA;            values='MetricValue',&#xA;            aggfunc='mean'&#xA;        )&#xA;       &#xA;        # Create chart&#xA;        fig, ax = plt.subplots(figsize=(14, 7))&#xA;        pivot_df.plot(kind='bar', ax=ax, color=['#667EEA', '#764BA2', '#F093FB'])&#xA;       &#xA;        ax.set_xlabel('Application', fontsize=12, fontweight='bold')&#xA;        ax.set_ylabel('CPU Usage (%)', fontsize=12, fontweight='bold')&#xA;        ax.set_title('CPU Performance by Application and Phase', fontsize=14, fontweight='bold')&#xA;        ax.legend(title='Phase', bbox_to_anchor=(1.05, 1), loc='upper left')&#xA;        ax.grid(axis='y', alpha=0.3)&#xA;        ax.set_xticklabels(ax.get_xticklabels(), rotation=45, ha='right')&#xA;       &#xA;        # Add threshold line&#xA;        ax.axhline(y=50, color='red', linestyle='--', linewidth=2, label='Threshold (50%)')&#xA;       &#xA;        plt.tight_layout()&#xA;       &#xA;        chart_path = os.path.join(output_folder, f'CPU_Comparison_{test_run_id}.png')&#xA;        plt.savefig(chart_path, dpi=300, bbox_inches='tight')&#xA;        plt.close()&#xA;       &#xA;        return chart_path&#xA;    except Exception as e:&#xA;        print(f'Error generating CPU comparison chart: {e}')&#xA;        return None&#xA;&#xA;&#xA;def generate_memory_comparison_chart(df, output_folder, test_run_id):&#xA;    &#xA;    try:&#xA;        # Filter memory metrics&#xA;        mem_df = df[df['MetricCategory'] == 'Memory']&#xA;       &#xA;        if mem_df.empty:&#xA;            return None&#xA;       &#xA;        # Pivot data&#xA;        pivot_df = mem_df.pivot_table(&#xA;            index='ApplicationName',&#xA;            columns='Phase',&#xA;            values='MetricValue',&#xA;            aggfunc='mean'&#xA;        )&#xA;       &#xA;        # Create chart&#xA;        fig, ax = plt.subplots(figsize=(14, 7))&#xA;        pivot_df.plot(kind='bar', ax=ax, color=['#11998E', '#38EF7D', '#20E3B2'])&#xA;       &#xA;        ax.set_xlabel('Application', fontsize=12, fontweight='bold')&#xA;        ax.set_ylabel('Memory Usage (MB)', fontsize=12, fontweight='bold')&#xA;        ax.set_title('Memory Performance by Application and Phase', fontsize=14, fontweight='bold')&#xA;        ax.legend(title='Phase', bbox_to_anchor=(1.05, 1), loc='upper left')&#xA;        ax.grid(axis='y', alpha=0.3)&#xA;        ax.set_xticklabels(ax.get_xticklabels(), rotation=45, ha='right')&#xA;       &#xA;        # Add threshold line&#xA;        ax.axhline(y=1000, color='red', linestyle='--', linewidth=2, label='Threshold (1000MB)')&#xA;       &#xA;        plt.tight_layout()&#xA;       &#xA;        chart_path = os.path.join(output_folder, f'Memory_Comparison_{test_run_id}.png')&#xA;        plt.savefig(chart_path, dpi=300, bbox_inches='tight')&#xA;        plt.close()&#xA;       &#xA;        return chart_path&#xA;    except Exception as e:&#xA;        print(f'Error generating memory comparison chart: {e}')&#xA;        return None&#xA;&#xA;&#xA;def generate_phase_comparison_chart(df, output_folder, test_run_id):&#xA;    &#xA;    try:&#xA;        # Get unique applications&#xA;        apps = df['ApplicationName'].unique()&#xA;       &#xA;        fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))&#xA;       &#xA;        # CPU comparison&#xA;        cpu_data = []&#xA;        for app in apps:&#xA;            app_df = df[df['ApplicationName'] == app]&#xA;            startup_cpu = app_df[&#xA;                (app_df['Phase'] == 'Startup') &amp;&#xA;                (app_df['MetricName'].str.contains('CPU'))&#xA;            ]['MetricValue'].mean()&#xA;            steady_cpu = app_df[&#xA;                (app_df['Phase'] == 'SteadyState') &amp;&#xA;                (app_df['MetricName'].str.contains('CPU'))&#xA;            ]['MetricValue'].mean()&#xA;            cpu_data.append({'App': app, 'Startup': startup_cpu, 'SteadyState': steady_cpu})&#xA;       &#xA;        cpu_df = pd.DataFrame(cpu_data).set_index('App')&#xA;        cpu_df.plot(kind='bar', ax=ax1, color=['#FA461