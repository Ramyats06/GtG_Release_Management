        <InArgument x:TypeArguments="x:String" x:Key="ImageFolderPath">[chartFolder]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="OutputPdfPath" xml:space="preserve">[in_OutputFolder + "SystemMetricsReport_" + timeStamp +  ".pdf"]</InArgument>
