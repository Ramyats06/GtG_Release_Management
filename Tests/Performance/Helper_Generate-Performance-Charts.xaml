3)&#xA;    $seriesProcess.IsValueShownAsLabel = $true&#xA;    $seriesProcess.LabelFormat = 'F3'&#xA;   &#xA;    $seriesWindow = New-Object System.Windows.Forms.DataVisualization.Charting.Series&#xA;    $seriesWindow.Name = 'Window Ready'&#xA;    $seriesWindow.ChartType = [System.Windows.Forms.DataVisualization.Charting.SeriesChartType]::StackedBar&#xA;    $seriesWindow.Color = [System.Drawing.Color]::FromArgb(255, 140, 80)&#xA;    $seriesWindow.IsValueShownAsLabel = $true&#xA;    $seriesWindow.LabelFormat = 'F3'&#xA;   &#xA;    $hasBreakdownData = $false&#xA;   &#xA;    foreach ($app in $apps) {&#xA;        $launchTime = $data | Where-Object {&#xA;            $_.ApplicationName -eq $app -and&#xA;            $_.MetricName -like '*_LaunchTime'&#xA;        } | Select-Object -First 1&#xA;       &#xA;        $processTime = $data | Where-Object {&#xA;            $_.ApplicationName -eq $app -and&#xA;            $_.MetricName -like '*_ProcessStartTime'&#xA;        } | Select-Object -First 1&#xA;       &#xA;        $windowTime = $data | Where-Object {&#xA;            $_.ApplicationName -eq $app -and&#xA;            $_.MetricName -like '*_WindowsReadyTime'&#xA;        } | Select-Object -First 1&#xA;       &#xA;        if ($launchTime -or $processTime -or $windowTime) {&#xA;            $launchVal = if ($launchTime) { [double]$launchTime.MetricValue } else { 0 }&#xA;            $processVal = if ($processTime) { [double]$processTime.MetricValue } else { 0 }&#xA;            $windowVal = if ($windowTime) { [double]$windowTime.MetricValue } else { 0 }&#xA;           &#xA;            $pointLaunch = $seriesLaunch.Points.Add($launchVal)&#xA;            $pointLaunch.AxisLabel = $app&#xA;           &#xA;            $pointProcess = $seriesProcess.Points.Add($processVal)&#xA;            $pointProcess.AxisLabel = $app&#xA;           &#xA;            $pointWindow = $seriesWindow.Points.Add($windowVal)&#xA;            $pointWindow.AxisLabel = $app&#xA;           &#xA;            $hasBreakdownData = $true&#xA;        }&#xA;    }&#xA;   &#xA;    if ($hasBreakdownData) {&#xA;        $chart1.Series.Add($seriesLaunch)&#xA;        $chart1.Series.Add($seriesProcess)&#xA;        $chart1.Series.Add($seriesWindow)&#xA;       &#xA;        $chart1.ChartAreas[0].AxisX.Title = 'Application'&#xA;        $chart1.ChartAreas[0].AxisY.Title = 'Time (Seconds)'&#xA;        $chart1.ChartAreas[0].AxisX.TitleFont = New-Object System.Drawing.Font('Segoe UI', 12, [System.Drawing.FontStyle]::Bold)&#xA;        $chart1.ChartAreas[0].AxisY.TitleFont = New-Object System.Drawing.Font('Segoe UI', 12, [System.Drawing.FontStyle]::Bold)&#xA;       &#xA;        $fileName1 = '01_StartupBreakdown_{0}.png' -f $TestRunID&#xA;        $chartPath1 = Save-Chart -Chart $chart1 -FileName $fileName1&#xA;        $chartPaths += $chartPath1&#xA;    }&#xA;&#xA;    $chart2 = New-ChartObject -Title 'Total Startup Time Comparison' -Width $chartWidth -Height $chartHeight&#xA;   &#xA;    $seriesTotalStartup = New-Object System.Windows.Forms.DataVisualization.Charting.Series&#xA;    $seriesTotalStartup.Name = 'Total Startup Time'&#xA;    $seriesTotalStartup.ChartType = [System.Windows.Forms.DataVisualization.Charting.SeriesChartType]::Bar&#xA;    $seriesTotalStartup.Color = [System.Drawing.Color]::FromArgb(250, 70, 22)&#xA;    $seriesTotalStartup.IsValueShownAsLabel = $true&#xA;    $seriesTotalStartup.LabelFormat = 'F2'&#xA;   &#xA;    $hasTotalStartupData = $false&#xA;   &#xA;    foreach ($app in $apps) {&#xA;        $totalStartup = $data | Where-Object {&#xA;            $_.ApplicationName -eq $app -and&#xA;            $_.MetricName -like '*_TotalStartupTime'&#xA;        } | Select-Object -First 1&#xA;       &#xA;        if ($totalStartup) {&#xA;            $point = $seriesTotalStartup.Points.Add([double]$totalStartup.MetricValue)&#xA;            $point.AxisLabel = $app&#xA;            $hasTotalStartupData = $true&#xA;        }&#xA;    }&#xA;   &#xA;    if ($hasTotalStartupData) {&#xA;        $chart2.Series.