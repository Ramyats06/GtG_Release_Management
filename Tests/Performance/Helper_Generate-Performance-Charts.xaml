    <ui:InvokePowerShell x:TypeArguments="x:String" ContinueOnError="{x:Null}" CommandText="param(&#xD;&#xA;    [System.Data.DataTable]$DataTable,&#xD;&#xA;    [string]$ImageFolderPath,&#xD;&#xA;    [string]$OutputPdfPath = 'SystemMetricsReport.pdf'&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;# Create HTML content&#xD;&#xA;$htmlContent = @'&#xD;&#xA;&lt;!DOCTYPE html&gt;&#xD;&#xA;&lt;html&gt;&#xD;&#xA;&lt;head&gt;&#xD;&#xA;    &lt;style&gt;&#xD;&#xA;        @page {&#xD;&#xA;            size: A4 landscape;&#xD;&#xA;            margin: 15mm;&#xD;&#xA;        }&#xD;&#xA;        body {&#xD;&#xA;            font-family: Arial, sans-serif;&#xD;&#xA;            margin: 20px;&#xD;&#xA;        }&#xD;&#xA;        h1 {&#xD;&#xA;            color: #333;&#xD;&#xA;            border-bottom: 2px solid #0078D4;&#xD;&#xA;            padding-bottom: 10px;&#xD;&#xA;            margin-bottom: 10px;&#xD;&#xA;        }&#xD;&#xA;        h2 {&#xD;&#xA;            color: #0078D4;&#xD;&#xA;            margin-top: 15px;&#xD;&#xA;            margin-bottom: 15px;&#xD;&#xA;            page-break-before: auto;&#xD;&#xA;            page-break-after: avoid;&#xD;&#xA;        }&#xD;&#xA;        h2.charts-heading {&#xD;&#xA;            margin-top: 10px;&#xD;&#xA;            margin-bottom: 10px;&#xD;&#xA;        }&#xD;&#xA;        table {&#xD;&#xA;            border-collapse: collapse;&#xD;&#xA;            width: 100%;&#xD;&#xA;            margin: 20px 0;&#xD;&#xA;            font-size: 10px;&#xD;&#xA;            page-break-inside: auto;&#xD;&#xA;        }&#xD;&#xA;        th {&#xD;&#xA;            background-color: #0078D4;&#xD;&#xA;            color: white;&#xD;&#xA;            padding: 8px;&#xD;&#xA;            text-align: left;&#xD;&#xA;            border: 1px solid #ddd;&#xD;&#xA;        }&#xD;&#xA;        td {&#xD;&#xA;            padding: 6px;&#xD;&#xA;            border: 1px solid #ddd;&#xD;&#xA;        }&#xD;&#xA;        tr {&#xD;&#xA;            page-break-inside: avoid;&#xD;&#xA;            page-break-after: auto;&#xD;&#xA;        }&#xD;&#xA;        tr:nth-child(even) {&#xD;&#xA;            background-color: #f2f2f2;&#xD;&#xA;        }&#xD;&#xA;        tr:hover {&#xD;&#xA;            background-color: #e6f2ff;&#xD;&#xA;        }&#xD;&#xA;        img {&#xD;&#xA;            max-width: 95%;&#xD;&#xA;            max-height: 450px;&#xD;&#xA;            width: auto;&#xD;&#xA;            height: auto;&#xD;&#xA;            margin: 5px auto;&#xD;&#xA;            border: 1px solid #ddd;&#xD;&#xA;            padding: 5px;&#xD;&#xA;            display: block;&#xD;&#xA;            object-fit: contain;&#xD;&#xA;        }&#xD;&#xA;        .image-container {&#xD;&#xA;            page-break-inside: avoid;&#xD;&#xA;            page-break-after: always;&#xD;&#xA;            margin: 10px 0;&#xD;&#xA;            text-align: center;&#xD;&#xA;            max-width: 100%;&#xD;&#xA;            overflow: hidden;&#xD;&#xA;        }&#xD;&#xA;        .image-container:first-of-type {&#xD;&#xA;            margin-top: 5px;&#xD;&#xA;        }&#xD;&#xA;        .image-container:last-child {&#xD;&#xA;            page-break-after: auto;&#xD;&#xA;        }&#xD;&#xA;        .image-container h3 {&#xD;&#xA;            margin: 5px 0 10px 0;&#xD;&#xA;            font-size: 14px;&#xD;&#xA;        }&#xD;&#xA;        .timestamp {&#xD;&#xA;            color: #666;&#xD;&#xA;            font-size: 0.9em;&#xD;&#xA;            margin: 5px 0;&#xD;&#xA;        }&#xD;&#xA;        .header-section {&#xD;&#xA;            margin-bottom: 5px;&#xD;&#xA;        }&#xD;&#xA;    &lt;/style&gt;&#xD;&#xA;&lt;/head&gt;&#xD;&#xA;&lt;body&gt;&#xD;&#xA;    &lt;div class='header-section'&gt;&#xD;&#xA;        &lt;h1&gt;System Metrics Report&lt;/h1&gt;&#xD;&#xA;        &lt;p class='timestamp'&gt;Generated: {TIMESTAMP}&lt;/p&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;   &#xD;&#xA;    &lt;h2 class='charts-heading'&gt;Metrics Charts&lt;/h2&gt;&#xD;&#xA;    {IMAGES}&#xD;&#xA;   &#xD;&#xA;    &lt;h2&gt;Metrics Data&lt;/h2&gt;&#xD;&#xA;    &lt;table&gt;&#xD;&#xA;        &lt;thead&gt;&#xD;&#xA;            &lt;tr&gt;&#xD;&#xA;                {TABLE_HEADERS}&#xD;&#xA;            &lt;/tr&gt;&#xD;&#xA;        &lt;/thead&gt;&#xD;&#xA;        &lt;tbody&gt;&#xD;&#xA;            {TABLE_ROWS}&#xD;&#xA;        &lt;/tbody&gt;&#xD;&#xA;    &lt;/table&gt;&#xD;&#xA;   &#xD;&#xA;&lt;/body&gt;&#xD;&#xA;&lt;/html&gt;&#xD;&#xA;'@&#xD;&#xA;&#xD;&#xA;# Replace timestamp&#xD;&#xA;$currentTime = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'&#xD;&#xA;$htmlContent = $htmlContent -replace '\{TIMESTAMP\}', $currentTime&#xD;&#xA;&#xD;&#xA;# Generate table headers&#xD;&#xA;$headers = ''&#xD;&#xA;foreach ($column in $DataTable.Columns) {&#xD;&#xA;    $columnName = $column.ColumnName&#xD;&#xA;    $headers += '&lt;th&gt;' + $columnName + '&lt;/th&gt;'&#xD;&#xA;}&#xD;&#xA;$htmlContent = $htmlContent -replace '\{TABLE_HEADERS\}', $headers&#xD;&#xA;&#xD;&#xA;# Generate table rows&#xD;&#xA;$rows = ''&#xD;&#xA;foreach ($row in $DataTable.Rows) {&#xD;&#xA;    $rows += '&lt;tr&gt;'&#xD;&#xA;    foreach ($column in $DataTable.Columns) {&#xD;&#xA;        $cellValue = $row[$column.ColumnName]&#xD;&#xA;        if ($null -eq $cellValue) {&#xD;&#xA;            $cellValue = ''&#xD;&#xA;        }&#xD;&#xA;        # Escape HTML special characters&#xD;&#xA;        $cellValue = [string]$cellValue&#xD;&#xA;        $cellValue = $cellValue -replace '&amp;', '&amp;amp;'&#xD;&#xA;        $cellValue = $cellValue -replace '&lt;', '&amp;lt;'&#xD;&#xA;        $cellValue = $cellValue -replace '&gt;', '&amp;gt;'&#xD;&#xA;        $rows += '&lt;td&gt;' + $cellValue + '&lt;/td&gt;'&#xD;&#xA;    }&#xD;&#xA;    $rows += '&lt;/tr&gt;'&#xD;&#xA;}&#xD;&#xA;$htmlContent = $htmlContent -replace '\{TABLE_ROWS\}', $rows&#xD;&#xA;&#xD;&#xA;# Generate image tags using certutil for base64 encoding&#xD;&#xA;$images = ''&#xD;&#xA;if (Test-Path $ImageFolderPath) {&#xD;&#xA;    $imageFiles = Get-ChildItem -Path $ImageFolderPath -Filter *.png | Sort-Object Name&#xD;&#xA;   &#xD;&#xA;    foreach ($imageFile in $imageFiles) {&#xD;&#xA;        # Use certutil to encode to base64&#xD;&#xA;        $tempB64File = $imageFile.FullName + '.b64'&#xD;&#xA;        certutil -encode $imageFile.FullName $tempB64File | Out-Null&#xD;&#xA;       &#xD;&#xA;        # Read the base64 file and clean it&#xD;&#xA;        $base64Lines = Get-Content $tempB64File&#xD;&#xA;        $base64 = ''&#xD;&#xA;        $startReading = $false&#xD;&#xA;        foreach ($line in $base64Lines) {&#xD;&#xA;            if ($line -match '^-----BEGIN CERTIFICATE-----$') {&#xD;&#xA;                $startReading = $true&#xD;&#xA;                continue&#xD;&#xA;            }&#xD;&#xA;            if ($line -match '^-----END CERTIFICATE-----$') {&#xD;&#xA;                break&#xD;&#xA;            }&#xD;&#xA;            if ($startReading) {&#xD;&#xA;                $base64 += $line&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;       &#xD;&#xA;        # Clean up temp file&#xD;&#xA;        Remove-Item $tempB64File -Force -ErrorAction SilentlyContinue&#xD;&#xA;       &#xD;&#xA;        # Get filename without extension&#xD;&#xA;        $fullName = $imageFile.Name&#xD;&#xA;        $lastDot = $fullName.LastIndexOf('.')&#xD;&#xA;        if ($lastDot -gt 0) {&#xD;&#xA;            $imageName = $fullName.Substring(0, $lastDot)&#xD;&#xA;        } else {&#xD;&#xA;            $imageName = $fullName&#xD;&#xA;        }&#xD;&#xA;       &#xD;&#xA;        # Build image HTML using string concatenation&#xD;&#xA;        $sq = [char]39&#xD;&#xA;        $imageHtml = '&lt;div class=' + $sq + 'image-container' + $sq + '&gt;'&#xD;&#xA;        $imageHtml += '&lt;h3&gt;' + $imageName + '&lt;/h3&gt;'&#xD;&#xA;        $imageHtml += '&lt;img src=' + $sq + 'data:image/png;base64,' + $base64 + $sq + ' alt=' + $sq + $imageName + $sq + ' /&gt;'&#xD;&#xA;        $imageHtml += '&lt;/div&gt;'&#xD;&#xA;       &#xD;&#xA;        $images += $imageHtml&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;$htmlContent = $htmlContent -replace '\{IMAGES\}', $images&#xD;&#xA;&#xD;&#xA;# Save HTML temporarily&#xD;&#xA;$timestamp = Get-Date -Format 'yyyyMMddHHmmss'&#xD;&#xA;$tempFileName = 'SystemMetricsReport_' + $timestamp + '.html'&#xD;&#xA;$tempFolder = [System.Environment]::GetEnvironmentVariable('TEMP')&#xD;&#xA;$tempHtmlPath = Join-Path -Path $tempFolder -ChildPath $tempFileName&#xD;&#xA;$htmlContent | Out-File -FilePath $tempHtmlPath -Encoding UTF8&#xD;&#xA;&#xD;&#xA;# Convert HTML to PDF using multiple methods (fallback approach)&#xD;&#xA;$pdfCreated = $false&#xD;&#xA;&#xD;&#xA;# Method 1: Try wkhtmltopdf if available&#xD;&#xA;$wkhtml = Get-Command wkhtmltopdf -ErrorAction SilentlyContinue&#xD;&#xA;if ($wkhtml) {&#xD;&#xA;    try {&#xD;&#xA;        &amp; wkhtmltopdf --orientation Landscape --page-size A4 --enable-local-file-access --image-quality 85 --image-dpi 96 --margin-top 10mm --margin-bottom 10mm $tempHtmlPath $OutputPdfPath&#xD;&#xA;        if (Test-Path $OutputPdfPath) {&#xD;&#xA;            $pdfCreated = $true&#xD;&#xA;            Write-Output ('PDF created successfully using wkhtmltopdf: ' + $OutputPdfPath)&#xD;&#xA;        }&#xD;&#xA;    } catch {&#xD;&#xA;        $errorMsg = $_.Exception.Message&#xD;&#xA;        Write-Warning ('wkhtmltopdf failed: ' + $errorMsg)&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;# Method 2: Try Chrome/Edge headless if available&#xD;&#xA;if (-not $pdfCreated) {&#xD;&#xA;    $chromePaths = @(&#xD;&#xA;        'C:\Program Files\Google\Chrome\Application\chrome.exe',&#xD;&#xA;        'C:\Program Files (x86)\Google\Chrome\Application\chrome.exe',&#xD;&#xA;        'C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe',&#xD;&#xA;        'C:\Program Files\Microsoft\Edge\Application\msedge.exe'&#xD;&#xA;    )&#xD;&#xA;   &#xD;&#xA;    $chromePath = $null&#xD;&#xA;    foreach ($path in $chromePaths) {&#xD;&#xA;        if (Test-Path $path) {&#xD;&#xA;            $chromePath = $path&#xD;&#xA;            break&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;   &#xD;&#xA;    if ($chromePath) {&#xD;&#xA;        try {&#xD;&#xA;            $pdfArg = '--print-to-pdf=' + $OutputPdfPath&#xD;&#xA;            &amp; $chromePath --headless --disable-gpu --run-all-compositor-stages-before-draw --print-to-pdf-no-header $pdfArg $tempHtmlPath&#xD;&#xA;            Start-Sleep -Seconds 3&#xD;&#xA;            if (Test-Path $OutputPdfPath) {&#xD;&#xA;                $pdfCreated = $true&#xD;&#xA;                Write-Output ('PDF created successfully using Chrome/Edge: ' + $OutputPdfPath)&#xD;&#xA;            }&#xD;&#xA;        } catch {&#xD;&#xA;            $errorMsg = $_.Exception.Message&#xD;&#xA;            Write-Warning ('Chrome/Edge headless failed: ' + $errorMsg)&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;# Method 3: Use Word COM object as fallback&#xD;&#xA;if (-not $pdfCreated) {&#xD;&#xA;    try {&#xD;&#xA;        $word = New-Object -ComObject Word.Application&#xD;&#xA;        $word.Visible = $false&#xD;&#xA;        $doc = $word.Documents.Open($tempHtmlPath)&#xD;&#xA;       &#xD;&#xA;        # Set orientation to landscape&#xD;&#xA;        $wdOrientLandscape = 1&#xD;&#xA;        $doc.PageSetup.Orientation = $wdOrientLandscape&#xD;&#xA;       &#xD;&#xA;        # Adjust margins for better fit&#xD;&#xA;        $doc.PageSetup.TopMargin = 28&#xD;&#xA;        $doc.PageSetup.BottomMargin = 28&#xD;&#xA;        $doc.PageSetup.LeftMargin = 36&#xD;&#xA;        $doc.PageSetup.RightMargin = 36&#xD;&#xA;       &#xD;&#xA;        # Save as PDF (format 17)&#xD;&#xA;        $wdFormatPDF = 17&#xD;&#xA;        $doc.SaveAs([ref]$OutputPdfPath, [ref]$wdFormatPDF)&#xD;&#xA;        $doc.Close()&#xD;&#xA;        $word.Quit()&#xD;&#xA;        [System.Runtime.Interopservices.Marshal]::ReleaseComObject($word) | Out-Null&#xD;&#xA;        $pdfCreated = $true&#xD;&#xA;        Write-Output ('PDF created successfully using Word COM: ' + $OutputPdfPath)&#xD;&#xA;    } catch {&#xD;&#xA;        $errorMsg = $_.Exception.Message&#xD;&#xA;        Write-Warning ('Word COM conversion failed: ' + $errorMsg)&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;# If PDF creation failed, keep the HTML file&#xD;&#xA;if (-not $pdfCreated) {&#xD;&#xA;    $finalHtmlPath = $OutputPdfPath -replace '\.pdf$', '.html'&#xD;&#xA;    Move-Item -Path $tempHtmlPath -Destination $finalHtmlPath -Force&#xD;&#xA;    Write-Output ('PDF conversion not available. HTML report saved to: ' + $finalHtmlPath)&#xD;&#xA;} else {&#xD;&#xA;    # Clean up temp HTML file&#xD;&#xA;    if (Test-Path $tempHtmlPath) {&#xD;&#xA;        Remove-Item -Path $tempHtmlPath -Force -ErrorAction SilentlyContinue&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;Write-Output 'Report generation completed.'&#xD;&#xA;&#xD;&#xA;" DisplayName="Invoke Power Shell - Generate PDF" sap:VirtualizedContainerService.HintSize="502,102" sap2010:WorkflowViewState.IdRef="InvokePowerShell`1_15" IsScript="True" PowerShellProcess="PowerShellCore">
