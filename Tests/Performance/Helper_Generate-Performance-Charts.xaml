icName',&#xA;            values='MetricValue',&#xA;            aggfunc='mean'&#xA;        )&#xA;       &#xA;        # Normalize data for better visualization&#xA;        heatmap_normalized = (heatmap_df - heatmap_df.min()) / (heatmap_df.max() - heatmap_df.min())&#xA;       &#xA;        # Create heatmap&#xA;        fig, ax = plt.subplots(figsize=(16, 8))&#xA;        sns.heatmap(&#xA;            heatmap_normalized,&#xA;            annot=heatmap_df,&#xA;            fmt='.2f',&#xA;            cmap='RdYlGn_r',&#xA;            cbar_kws={'label': 'Normalized Value'},&#xA;            linewidths=0.5,&#xA;            ax=ax&#xA;        )&#xA;       &#xA;        ax.set_title('Performance Metrics Heatmap (All Applications)', fontsize=14, fontweight='bold')&#xA;        ax.set_xlabel('Metric', fontsize=12, fontweight='bold')&#xA;        ax.set_ylabel('Application', fontsize=12, fontweight='bold')&#xA;       &#xA;        plt.xticks(rotation=45, ha='right')&#xA;        plt.tight_layout()&#xA;       &#xA;        chart_path = os.path.join(output_folder, f'Heatmap_{test_run_id}.png')&#xA;        plt.savefig(chart_path, dpi=300, bbox_inches='tight')&#xA;        plt.close()&#xA;       &#xA;        return chart_path&#xA;    except Exception as e:&#xA;        print(f'Error generating heatmap: {e}')&#xA;        return None&#xA;&#xA;&#xA;def generate_time_series_chart(df, output_folder, test_run_id):&#xA;   &#xA;    try:&#xA;        if 'Timestamp' not in df.columns:&#xA;            return None&#xA;       &#xA;        # Convert timestamp to datetime&#xA;        df['Timestamp'] = pd.to_datetime(df['Timestamp'])&#xA;       &#xA;        fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 10))&#xA;       &#xA;        # CPU over time&#xA;        for app in df['ApplicationName'].unique():&#xA;            app_df = df[&#xA;                (df['ApplicationName'] == app) &amp;&#xA;                (df['MetricName'].str.contains('CPU_Average'))&#xA;            ].sort_values('Timestamp')&#xA;           &#xA;            if not app_df.empty:&#xA;                ax1.plot(&#xA;                    app_df['Timestamp'],&#xA;                    app_df['MetricValue'],&#xA;                    marker='o',&#xA;                    label=app,&#xA;                    linewidth=2&#xA;                )&#xA;       &#xA;        ax1.set_title('CPU Usage Over Time', fontsize=12, fontweight='bold')&#xA;        ax1.set_ylabel('CPU Usage (%)')&#xA;        ax1.legend()&#xA;        ax1.grid(alpha=0.3)&#xA;       &#xA;        # Memory over time&#xA;        for app in df['ApplicationName'].unique():&#xA;            app_df = df[&#xA;                (df['ApplicationName'] == app) &amp;&#xA;                (df['MetricName'].str.contains('Memory_Average'))&#xA;            ].sort_values('Timestamp')&#xA;           &#xA;            if not app_df.empty:&#xA;                ax2.plot(&#xA;                    app_df['Timestamp'],&#xA;                    app_df['MetricValue'],&#xA;                    marker='s',&#xA;                    label=app,&#xA;                    linewidth=2&#xA;                )&#xA;       &#xA;        ax2.set_title('Memory Usage Over Time', fontsize=12, fontweight='bold')&#xA;        ax2.set_ylabel('Memory Usage (MB)')&#xA;        ax2.set_xlabel('Time')&#xA;        ax2.legend()&#xA;        ax2.grid(alpha=0.3)&#xA;       &#xA;        plt.tight_layout()&#xA;       &#xA;        chart_path = os.path.join(output_folder, f'TimeSeries_{test_run_id}.png')&#xA;        plt.savefig(chart_path, dpi=300, bbox_inches='tight')&#xA;        plt.close()&#xA;       &#xA;        return chart_path&#xA;    except Exception as e:&#xA;        print(f'Error generating time series chart: {e}')&#xA;        return None&#xA;&#xA;&#xA;# Entry point for UiPath&#xA;if __name__ == '__main__':&#xA;    import sys&#xA;    if len(sys.argv) &gt;= 4:&#xA;        csv_path = sys.argv[1]&#xA;        output_folder = sys.argv[2]&#xA;        test_run_id = sys.argv[3]&#xA;        result = generate_all_charts(csv_path, output_